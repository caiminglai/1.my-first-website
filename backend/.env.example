# 同物异名后端环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ===== 服务端口 =====
PORT=3000

# ===== 运行环境 =====
# development | production
NODE_ENV=development

# ===== 管理后台密钥（必填）=====
# 管理接口通过请求头 x-admin-token 校验
ADMIN_TOKEN=your_secure_admin_token_here

# ===== 前端地址（CORS 白名单，必填）=====
# 需与 vite.config.ts 中的端口一致（默认 3001）
FRONTEND_URL=http://localhost:3001

# ===== 数据库路径（可选）=====
# 默认 data/tongwuyiming.db，一般无需设置
# DB_PATH=/path/to/your/database.db

# ===== AI 功能（可选）=====
# AI 问答的 API Key 由前端传入，此处仅作备用
# OPENAI_API_KEY=sk-xxx
