# ===== 同物异名 · 环境变量配置 =====
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# 后端服务端口（默认 3000）
PORT=3000

# 前端地址（用于 CORS 跨域允许，开发环境含端口）
FRONTEND_URL=http://localhost:3001

# 运行环境：development | production
NODE_ENV=development

# 数据库文件路径（相对于 backend/ 目录）
DB_PATH=../data/tongwuyiming.db

# 管理后台认证 Token（请修改为复杂随机字符串）
ADMIN_TOKEN=your-secret-token-here

# Obsidian 知识库路径（用于 Obsidian 双向同步，可选）
OBSIDIAN_VAULT_PATH=../obsidian
