# ============================================================
# 同物异名 - Git 忽略规则
# 项目架构：前端(app) + 后端(backend) + 数据库(data)
# ============================================================


# ============================================================
# 1. 依赖包目录
# ============================================================
# Node.js 依赖，由 package.json 管理，无需提交
**/node_modules/


# ============================================================
# 2. 环境变量与密钥
# ============================================================
# 环境变量文件，包含敏感信息（数据库密码、API Key等），严禁提交
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# 保留 .env.example 作为配置模板（不含真实密钥）
!.env.example


# ============================================================
# 3. 构建产物
# ============================================================
# Vite / 前端构建输出目录
**/dist/
**/dist-ssr/
**/build/
**/out/

# TypeScript 编译输出
**/*.tsbuildinfo


# ============================================================
# 4. 日志文件
# ============================================================
# 各种日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 后端运行日志
backend/logs/


# ============================================================
# 5. 数据库文件
# ============================================================
# SQLite 主数据库文件（含真实业务数据，不提交到仓库）
*.db

# SQLite 临时文件（WAL模式共享内存文件）
*.db-shm
*.db-wal
*.db-journal

# 例外：主数据库体积很小，纳入 Git 作为安全快照
!data/同物异名.db

# 数据库备份目录（含历史备份）
data/backups/

# Meilisearch 搜索引擎索引数据（运行时自动生成，无需提交）
backend/meili_data/

# Meilisearch 可执行文件（二进制，不纳入 Git 管理）
backend/bin/

# 注：如需提交空的 data 目录结构，可在 data/backups/ 下放 .gitkeep


# ============================================================
# 6. 缓存文件
# ============================================================
# 各种工具的缓存目录
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/

# Vite 缓存
**/.vite/

# 临时缓存文件
*.tmp
*.temp


# ============================================================
# 7. 编辑器与 IDE
# ============================================================
# VS Code 工作区配置（团队共享配置建议放到 .vscode/settings.json 中）
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# WebStorm / JetBrains 系列
.idea/
*.iml
*.ipr
*.iws

# Vim 交换文件
*.swp
*.swo
*~

# Sublime Text
*.sublime-workspace


# ============================================================
# 8. 操作系统文件
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ============================================================
# 9. 测试与覆盖率
# ============================================================
# 测试覆盖率报告
**/coverage/
**/.nyc_output/

# 测试快照（根据团队约定决定是否提交）
# **/__snapshots__/


# ============================================================
# 10. 压缩包与文档
# ============================================================
# 压缩文件
*.zip
*.rar
*.7z
*.tar
*.gz

# Office 文档（通常是二进制，不适合 Git 管理）
# 如确需提交，可在文件前添加 ! 取消忽略
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx


# ============================================================
# 11. 数据导出文件
# ============================================================
# JSON 数据导出（如果是自动生成的临时文件，不提交）
# 注：项目中的 all_terms.json 等是初始数据，需要保留，故不在这里忽略
# data/*.json


# ============================================================
# 12. 其他
# ============================================================
# 图片资源（如大量图片建议用 CDN 或 Git LFS）
# 本项目图片较少，正常提交
# *.png
# *.jpg
# *.jpeg
# *.gif
# *.svg

# 锁文件说明：
# - package-lock.json 应该提交，以确保依赖版本一致
# - 本项目已在 app/ 和 backend/ 下各自提交 package-lock.json


# ============================================================
# 13. Obsidian 知识库
# ============================================================
# 工作区状态（每次开关 Obsidian 都会变，无需提交）
obsidian/.obsidian/workspace.json
obsidian/.obsidian/workspace-mobile.json

# 插件和主题代码（体积大，换环境手动重装）
obsidian/.obsidian/plugins/
obsidian/.obsidian/themes/

# 插件运行时数据（缓存、索引等）
obsidian/.obsidian/plugins/*/data.json

# Obsidian 画布和插件临时文件
obsidian/**/*.canvas
obsidian/**/*.base
